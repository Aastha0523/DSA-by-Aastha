   "source": [
    "class Solution:\n",
    "    def twoSum(self, nums: List[int], target: int) -> List[int]:\n",
    "        preMap = {}\n",
    "        for i, n in enumerate(nums):\n",
    "            diff = target - n\n",
    "            if diff in preMap:\n",
    "                return [preMap[diff],i]\n",
    "            preMap[n] = i\n",
    "        return\n"
   ]
